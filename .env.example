# AXON configuration — copy this file to ".env" and fill in your own values.
#   cp .env.example .env
#
# Format rules: KEY=value on one line, no spaces around "=", no quotes needed.

# --- Hugging Face (primary synthesis provider) ---
# Get a free "Read" token at https://huggingface.co/settings/tokens
HUGGINGFACEHUB_ACCESS_TOKEN=hf_your_token_here

# The open model used to write answers. IMPORTANT: it must be available on the
# serverless Inference API for YOUR token/tier — not all models are. If answers
# silently fall back to raw passages, your token can't serve this model; pick a
# smaller instruct model below.
#   Known to work broadly on the free tier:
#     meta-llama/Llama-3.1-8B-Instruct
#     Qwen/Qwen2.5-7B-Instruct
#   Larger / reasoning models (need a paid tier or Inference Providers access):
#     Qwen/Qwen3-32B
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Anthropic Claude (optional automatic fallback if HF is unavailable) ---
# ANTHROPIC_API_KEY=sk-ant-...
